{
    // ─────────────────────────────────────────────────────────────┤ header ├───
    "layer": "bottom",
    "position": "bottom",
    "exclusive": false,
    "reload_style_on_change": true,
    "gtk-layer-shell": true,
    // ──────────────────────────────────────────────────────────┤ positions ├───
