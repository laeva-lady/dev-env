)

cargo_pkgs=(
    kickoff
)

if [[ " $* " == *" nopac "* ]]
then
    echo "Skipping pacman..."
else
    echo "Checking pacman..."
    sudo pacman -Syu --needed "${packages[@]}"
fi

if [[ " $* " == *" aur "* ]]
then
    echo "Checking AUR..."
    yay -S --needed "${aur[@]}"
else
    echo "Skipping AUR..."
fi

if [[ " $* " == *" cargo "* ]]
then
    echo "Checking Cargo"
    cargo install "${cargo_pkgs[@]}"
else
    echo "Skipping Cargo"
fi
