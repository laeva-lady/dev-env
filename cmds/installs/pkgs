    "${wm[@]}"
)



if [[ " $* " == *" nopac "* ]]
then
    echo "skipping pacman..."
else
    echo "Checking official repos..."
    sudo pacman -Syu --needed "${packages[@]}"
fi

if [[ " $* " == *" aur "* ]]
then
    echo "Checking AUR..."
    yay -S --needed "${aur[@]}"
else
    echo "Skipping AUR..."
fi
