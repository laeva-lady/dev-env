#!/usr/bin/python

import os
import shutil
import subprocess
from pathlib import Path
import sys

DEV_ENV = Path(os.environ.get("DEV_ENV", ""))

DOTFILES = DEV_ENV / "dotfiles.sh"

def get_dotfile_vars(dotfiles_path):
    result = subprocess.run(
        ["bash", "-c", f"source {dotfiles_path} && printf '%s\\n' \"${{confs[*]}}\" \"${{envs[*]}}\""],
        capture_output=True,
        text=True,
        check=True,
        executable="/bin/bash",
    )
    lines = result.stdout.strip().splitlines()
    half = len(lines) // 2
    dotfiles = lines[:half]
    rc_files = lines[half:]

    return dotfiles[0].split(" "), rc_files[0].split(" ")

def update_config_files(config_items):
    config_base = DEV_ENV / "env" / ".config"
    shutil.rmtree(config_base, ignore_errors=True)
    config_base.mkdir(parents=True, exist_ok=True)

    for item in config_items:
        source = Path.home() / ".config" / item
        dest = config_base / item
        print(f"\t\t{item}")

        if source.is_symlink():
            print(f"\t\tSkipping top-level symlink: {item}")
            continue
        elif source.is_file():
            shutil.copy2(source, dest)
        elif source.is_dir():
            for root, dirs, files in os.walk(source):
                rel_path = Path(root).relative_to(source)
                dest_path = dest / rel_path
                dest_path.mkdir(parents=True, exist_ok=True)

                for file in files:
                    src_file = Path(root) / file
                    if not src_file.is_symlink():
                        dst_file = dest_path / file
                        shutil.copy2(src_file, dst_file)

        git_dir = dest / ".git"
        if git_dir.exists():
            shutil.rmtree(git_dir)

def update_env_files(env_files: list[str]):
    env_base = DEV_ENV / "env"
    for env_file in env_files:
        print(f"\t\t{env_file}")
        src = Path.home() / env_file
        dst = env_base / Path(env_file).name
        if src.is_dir():
            shutil.copytree(src, dst, dirs_exist_ok=True)
        else:
            shutil.copy2(src, dst)

def sync_files():
    confs, envs = get_dotfile_vars(DOTFILES)
    print("Updating config files")
    update_config_files(confs)

    print("Copying envs files")
    update_env_files(envs)

    print("Copying vscode user settings")
    code_dest = DEV_ENV / "resources" / "Code"
    code_dest.mkdir(parents=True, exist_ok=True)
    shutil.copy2(Path.home() / ".config/Code/User/settings.json", code_dest)
    shutil.copy2(Path.home() / ".config/Code/User/keybindings.json", code_dest)

    print("Copying icons")
    subprocess.run(["rsync", "-a", os.path.expanduser("~/.local/share/icons/"), os.path.join(DEV_ENV, "resources/icons")])

    print("Copying themes")
    subprocess.run(["rsync", "-a", os.path.expanduser("~/.themes/"), os.path.join(DEV_ENV, "resources/themes")])

def sync_remote():
    print("Checking git repo")
    subprocess.run(["git", "-C", str(DEV_ENV), "-c", "color.status=always", "status"])

    result = subprocess.run(
        ["git", "-C", str(DEV_ENV), "status", "--porcelain"],
        capture_output=True, text=True
    )
    if result.stdout.strip() == "":
        return

    subprocess.run(["git", "-C", str(DEV_ENV), "add", "."], check=True)
    subprocess.run(["git", "-C", str(DEV_ENV), "commit", "-m", "chore: automated commit"], check=True)
    subprocess.run(["git", "-C", str(DEV_ENV), "push"], check=True)

def main():
    if len(sys.argv) > 1:
        arg = sys.argv[1]
        if arg == "vim":
            subprocess.run(["nvim", str(DOTFILES)])
        elif arg == "zen":
            subprocess.run(["zen-browser", "--new-tab", "https://github.com/laeva-lady/dev-env"])
        elif arg in ("-s", "--sync"):
            sync_files()
            sync_remote()
        else:
            sync_files()
    else:
        sync_files()

if __name__ == "__main__":
    main()
