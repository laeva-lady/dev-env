#!/usr/bin/env bash

JSON_PATH="$HOME/personal/dev-env/resources/pkg.json"
SCRIPT_PATH="$0"
CMD="$1"
shift

ROOTCMD="sudo"
command -v doas &>/dev/null && ROOTCMD="doas"

get_pkgs_by_category() {
    jq -r --arg category "$1" '.[$category][]' "$JSON_PATH"
}

get_all_pkgs() {
    jq -r 'to_entries[] | select(.key != "aur") | .value[]' "$JSON_PATH"
}

get_aur_pkgs() {
    jq -r '.aur[]' "$JSON_PATH"
}

add_pkg() {
    local pkg_to_add="$1"
    if [ -z "$pkg_to_add" ]; then
        echo "Usage: add <pkg_name>"
        return 1
    fi

    if jq -e --arg pkg "$pkg_to_add" 'any(to_entries[]; .value[] == $pkg)' "$JSON_PATH" &>/dev/null; then
        echo "❗ Package '$pkg_to_add' already exists in the JSON file."
        return 0
    fi

    jq --arg pkg "$pkg_to_add" '.to_organize += [$pkg]' "$JSON_PATH" >"$JSON_PATH.tmp" && mv "$JSON_PATH.tmp" "$JSON_PATH"
    echo "📦 Added '$pkg_to_add' to 'to_organize'"
}

list_pkgs() {
    echo "📦 Packages by category:"
    jq -r '
        to_entries[] |
        "🗂️  \(.key):\n" + (
            (.value | map("  - " + .)) | join("\n")
        ) + "\n"
    ' "$JSON_PATH"
}

search_pkg() {
    yay -Ss "$1"
}

remove_pkg() {
    local pkg_to_remove="$1"
    if [ -z "$pkg_to_remove" ]; then
        echo "Usage: remove <pkg_name>"
        return 1
    fi

    if ! jq -e --arg pkg "$pkg_to_remove" 'any(to_entries[]; .value[] == $pkg)' "$JSON_PATH" &>/dev/null; then
        echo "❗ Package '$pkg_to_remove' not found in any category."
        return 0
    fi

    jq --arg pkg "$pkg_to_remove" '
        with_entries(.value |= map(select(. != $pkg)))
    ' "$JSON_PATH" >"$JSON_PATH.tmp" && mv "$JSON_PATH.tmp" "$JSON_PATH"
    yay -Rs "$pkg_to_remove"
    echo "📦 Removed '$pkg_to_remove'"
}

case "$CMD" in
"add" | "a")
    add_pkg "$@"
    ;;

"remove" | "r")
    remove_pkg "$@"
    ;;
"list" | "l")
    list_pkgs
    ;;
"search" | "s")
    search_pkg "$1"
    ;;
"query" | "q")
    list_pkgs | grep "$1" | awk '{print $2}'
    ;;
"qi")
    pacman -Qi "$1"
    ;;
"vim" | "v")
    nvim "$JSON_PATH"
    ;;
"")
    echo "Updating repos..."
    yay

    echo "Checking repo..."
    mapfile -t all_pkgs < <(get_all_pkgs)
    $ROOTCMD pacman -S --needed "${all_pkgs[@]}"

    echo "Checking AUR..."
    mapfile -t aur_pkgs < <(get_aur_pkgs)
    yay -S --needed "${aur_pkgs[@]}"
    yay -S --needed "${to_organized[@]}"
    ;;
*)
    echo "❗ Unknown command: $CMD"
    echo "Usage: $0 [add <pkg>] | [remove <pkg>] | [list] | [vim] | [install] | [search <pkg>]"
    exit 1
    ;;
esac
